// ===== 11. ENHANCED REACT VERSION (OPTIONAL) =====
// If you prefer React components, here's the React version:

import * as React from 'react';
import * as ReactDom from 'react-dom';
import { Version } from '@microsoft/sp-core-library';
import { BaseClientSideWebPart } from '@microsoft/sp-webpart-base';
import { SPHttpClient } from '@microsoft/sp-http';

import ApiIntegrationComponent from './components/ApiIntegrationComponent';
import { IApiIntegrationProps } from './components/IApiIntegrationProps';

// React Component Interface
export interface IApiIntegrationProps {
  title: string;
  spHttpClient: SPHttpClient;
  siteUrl: string;
  enableLogging: boolean;
  apiEndpoints: string[];
}

// React Component State
export interface IApiIntegrationState {
  results: IApiResponse[];
  logs: ILogEntry[];
  loading: { [key: string]: boolean };
  status: { type: string; message: string } | null;
}

export interface ILogEntry {
  timestamp: string;
  type: 'info' | 'success' | 'error' | 'warning';
  message: string;
}

// React Component Implementation
export default class ApiIntegrationComponent extends React.Component<IApiIntegrationProps, IApiIntegrationState> {
  constructor(props: IApiIntegrationProps) {
    super(props);
    
    this.state = {
      results: [],
      logs: [{ timestamp: new Date().toISOString(), type: 'info', message: 'Component initialized' }],
      loading: {},
      status: null
    };
  }

  private async makeApiCall(url: string, buttonId: string, description: string): Promise<void> {
    this.setState(prevState => ({
      loading: { ...prevState.loading, [buttonId]: true },
      status: { type: 'loading', message: `Fetching ${description}...` }
    }));

    this.addLog('info', `API Call: ${url}`);

    try {
      const response = await fetch(url);
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      const data = await response.json();
      const result: IApiResponse = {
        data,
        timestamp: new Date().toISOString(),
        endpoint: url
      };

      this.setState(prevState => ({
        results: [result, ...prevState.results.slice(0, 9)], // Keep last 10 results
        loading: { ...prevState.loading, [buttonId]: false },
        status: { type: 'success', message: `Successfully fetched ${description}` }
      }));

      this.addLog('success', `API Success: ${description}`);

    } catch (error) {
      const result: IApiResponse = {
        error: error.message,
        timestamp: new Date().toISOString(),
        endpoint: url
      };

      this.setState(prevState => ({
        results: [result, ...prevState.results.slice(0, 9)],
        loading: { ...prevState.loading, [buttonId]: false },
        status: { type: 'error', message: `Failed: ${error.message}` }
      }));

      this.addLog('error', `API Error: ${error.message}`);
    }

    // Clear status after 5 seconds
    setTimeout(() => {
      this.setState({ status: null });
    }, 5000);
  }

  private addLog(type: ILogEntry['type'], message: string): void {
    if (!this.props.enableLogging) return;

    const newLog: ILogEntry = {
      timestamp: new Date().toISOString(),
      type,
      message
    };

    this.setState(prevState => ({
      logs: [newLog, ...prevState.logs.slice(0, 99)] // Keep last 100 logs
    }));
  }

  private clearLogs = (): void => {
    this.setState({ logs: [] });
    this.addLog('info', 'Logs cleared');
  }

  private exportData = (): void => {
    const dataStr = JSON.stringify(this.state.results, null, 2);
    const dataBlob = new Blob([dataStr], { type: 'application/json' });
    
    const url = URL.createObjectURL(dataBlob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `sharepoint-api-data-${new Date().toISOString().split('T')[0]}.json`;
    link.click();
    
    URL.revokeObjectURL(url);
    this.addLog('success', 'Data exported successfully');
  }

  public render(): React.ReactElement<IApiIntegrationProps> {
    const { title } = this.props;
    const { results, logs, loading, status } = this.state;

    return (
      <div className="api-integration-react">
        <div className="header">
          <h2>{title}</h2>
          <p>Real-time API integration with React components</p>
        </div>

        <div className="button-grid">
          <button 
            onClick={() => this.makeApiCall('https://jsonplaceholder.typicode.com/users/1', 'userBtn', 'User Data')}
            disabled={loading.userBtn}
            className={`api-button ${loading.userBtn ? 'loading' : ''}`}
          >
            {loading.userBtn ? 'Loading...' : '👤 User Data'}
          </button>

          <button 
            onClick={() => this.makeApiCall('https://jsonplaceholder.typicode.com/posts?_limit=5', 'postsBtn', 'Posts')}
            disabled={loading.postsBtn}
            className={`api-button ${loading.postsBtn ? 'loading' : ''}`}
          >
            {loading.postsBtn ? 'Loading...' : '📝 Posts'}
          </button>

          <button 
            onClick={() => this.makeApiCall('https://jsonplaceholder.typicode.com/todos?_limit=10', 'todoBtn', 'Todos')}
            disabled={loading.todoBtn}
            className={`api-button ${loading.todoBtn ? 'loading' : ''}`}
          >
            {loading.todoBtn ? 'Loading...' : '✅ Todos'}
          </button>
        </div>

        <div className="controls">
          <button onClick={this.clearLogs}>Clear Logs</button>
          <button onClick={this.exportData}>Export Data</button>
        </div>

        {status && (
          <div className={`status status-${status.type}`}>
            {status.message}
          </div>
        )}

        <div className="results-section">
          <h3>Results ({results.length})</h3>
          <div className="results-container">
            {results.length === 0 ? (
              <div className="no-data">No data yet. Click an API button above.</div>
            ) : (
              results.map((result, index) => (
                <div key={index} className="result-item">
                  <div className="result-header">
                    <span className="endpoint">{result.endpoint}</span>
                    <span className="timestamp">{new Date(result.timestamp).toLocaleTimeString()}</span>
                  </div>
                  <div className="result-data">
                    {result.error ? (
                      <div className="error">Error: {result.error}</div>
                    ) : (
                      <pre className="json-data">{JSON.stringify(result.data, null, 2)}</pre>
                    )}
                  </div>
                </div>
              ))
            )}
          </div>
        </div>

        <div className="logs-section">
          <h3>Activity Logs ({logs.length})</h3>
          <div className="logs-container">
            {logs.map((log, index) => (
              <div key={index} className={`log-entry log-${log.type}`}>
                <span className="timestamp">[{new Date(log.timestamp).toLocaleTimeString()}]</span>
                <span className="message">{log.message}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  }
}

// React Web Part Implementation
export default class ApiIntegrationReactWebPart extends BaseClientSideWebPart<IApiIntegrationWebPartProps> {
  public render(): void {
    const element: React.ReactElement<IApiIntegrationProps> = React.createElement(
      ApiIntegrationComponent,
      {
        title: this.properties.title,
        spHttpClient: this.context.spHttpClient,
        siteUrl: this.context.pageContext.web.absoluteUrl,
        enableLogging: this.properties.enableLogging,
        apiEndpoints: this.properties.apiEndpoints ? this.properties.apiEndpoints.split(',').map(e => e.trim()) : []
      }
    );

    ReactDom.render(element, this.domElement);
  }

  protected onDispose(): void {
    ReactDom.unmountComponentAtNode(this.domElement);
  }

  // ... same property pane configuration as above
}

// ===== 12. INSTALLATION & DEPLOYMENT INSTRUCTIONS =====
/*
STEP-BY-STEP DEPLOYMENT GUIDE:

1. PREREQUISITES:
   - Node.js 16.x or 18.x (LTS versions)
   - PowerShell (for deployment)
   - SharePoint Online tenant with admin access

2. SETUP DEVELOPMENT ENVIRONMENT:
   npm install -g yo @microsoft/generator-sharepoint gulp-cli

3. CREATE PROJECT:
   yo @microsoft/sharepoint
   - Choose: "SharePoint Online only"
   - Choose: "Use the current folder"
   - Choose: "TypeScript" or "React"
   - Choose: "WebPart"
   - Name: "ApiIntegrationWebPart"

4. REPLACE FILES:
   Copy all the code above into respective files:
   - src/webparts/apiIntegration/ApiIntegrationWebPart.ts
   - src/webparts/apiIntegration/ApiIntegrationWebPart.module.scss
   - config/package-solution.json
   - And other configuration files

5. BUILD AND DEPLOY:
   npm install
   gulp build --ship
   gulp bundle --ship
   gulp package-solution --ship

6. UPLOAD TO SHAREPOINT:
   - Go to SharePoint Admin Center
   - Navigate to More features > Apps > App Catalog
   - Upload the .sppkg file from sharepoint/solution folder
   - Click "Deploy"

7. ADD TO SHAREPOINT SITE:
   - Go to your SharePoint site
   - Edit any page
   - Click + to add web part
   - Search for "API Integration"
   - Add the web part to your page

8. CONFIGURE:
   - Click the web part settings (pencil icon)
   - Configure title, API endpoints, logging, etc.
   - Save and publish the page

SECURITY NOTES:
- This web part makes external API calls
- Ensure your SharePoint tenant allows external connections
- For production, implement proper authentication for secured APIs
- Consider using Azure Functions as proxy for sensitive API calls

TROUBLESHOOTING:
- If build fails, check Node.js version compatibility
- Ensure all dependencies are correctly installed
- Check browser console for runtime errors
- Verify API endpoints are accessible from SharePoint Online
*/