#!/bin/bash
# check the latest version of the veracode wrapper and the SCA agent currently installed
# if the veracode sca command is pased switch to leveraging the sca agent
# if any other parameter is used, switch to passing the parameter to veracode cli

shopt -s expand_aliases
source ~/.bashrc

PM="docker"
SPM="apt"
VERSION="0.0.11-13-25"

#set -euo pipefail
alias 'veracode-api'='docker run -it --rm -v $PWD:/home/luser -v ~/.veracode/credentials:/home/luser/.veracode/credentials veracode/api-wrapper-java:cmd'
alias 'veracode-shc'='docker run -t -v "$HOME/.veracode:/.veracode" antfie/scan_health'
alias 'veracode-http'='docker run -it --rm -v $PWD:/home/luser -v ~/.veracode/credentials:/home/luser/.veracode/credentials veracode/api-signing:cmd'

# Ensure at least one argument is provided
help(){
if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <command> [args...]"
    echo "$0 sca    - to use the SCA agent"
    echo "$0 cli    - to use the veracode cli"
    echo "$0 api    - to use the veracode api wrapper"
    echo "$0 shc    - to use the veracode scan health check"
    echo "$0 update - update the tool version"
    exit 1
fi
}

